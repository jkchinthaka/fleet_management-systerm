NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=Fleet_New
DB_HOST=localhost
DB_PORT=1433
DB_NAME=fleet_db
DB_USER=sa
DB_PASSWORD=<sql_server_password>
DB_ENCRYPT=false
DB_TRUST_CERT=true
DB_AUTO_SYNC=true
SQLSERVER_CONNECTION_STRING=Data Source=localhost,1433;Persist Security Info=True;User ID=<sql_user>;Password=<sql_password>;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Command Timeout=30
SQL_DB_NAME=NELNA_APP
SQL_BACKUP_SCHEMA=mongo_backup
JWT_SECRET=<strong_jwt_secret>
JWT_EXPIRES_IN=8h
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
